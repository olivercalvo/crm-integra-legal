# Plantilla de variables de entorno para CRM Integra Legal.
# Copiar a .env.local y completar con los valores reales (proporcionados por el cliente).
# NUNCA commitear .env.local — solo este archivo de ejemplo.

# Supabase - CUENTA DEL CLIENTE (Integra Legal)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=
CRON_SECRET=

# eFactura PTY (PAC ideati)
# EFACTURA_I_AMB: 1=produccion, 2=pruebas
EFACTURA_API_BASE_URL=
EFACTURA_I_AMB=
EFACTURA_API_KEY=

# eFactura PTY — identidad del emisor (Integra Legal)
# Estos valores los provee el cliente. loadEmisorConfig() valida que TODOS
# los requeridos estén presentes y rompe explícitamente si falta alguno.
EFACTURA_EMISOR_RUC=
EFACTURA_EMISOR_DV=
# 1=persona natural, 2=persona juridica (Integra Legal = 2)
EFACTURA_EMISOR_TIPO_CONTRIBUYENTE=
EFACTURA_EMISOR_RAZON_SOCIAL=
EFACTURA_EMISOR_SUCURSAL=
EFACTURA_EMISOR_DIRECCION=
EFACTURA_EMISOR_UBICACION_CODIGO=
EFACTURA_EMISOR_CORREGIMIENTO=
EFACTURA_EMISOR_DISTRITO=
EFACTURA_EMISOR_PROVINCIA=
EFACTURA_EMISOR_TELEFONO=
EFACTURA_EMISOR_EMAIL=
# Punto de facturacion DGI: 3 digitos numericos, != "000". Integra arranca con 001.
EFACTURA_EMISOR_PUNTO_FACTURACION=
# PLACEHOLDER — codigo DGI no confirmado todavia. Default "03" si se deja vacio.
EFACTURA_EMISOR_FORMA_PAGO_DEFAULT=
# Codigos CPBS de servicios legales (sustituir 0 por el valor real).
# HON = honorarios profesionales, REI = reembolso de gastos.
# CPBS_REI es PLACEHOLDER — pendiente de confirmar con el cliente.
EFACTURA_EMISOR_CPBS_HON=
EFACTURA_EMISOR_CPBS_REI=
