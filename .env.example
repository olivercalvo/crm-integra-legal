# Plantilla de variables de entorno para CRM Integra Legal.
# Copiar a .env.local y completar con los valores reales (proporcionados por el cliente).
# NUNCA commitear .env.local — solo este archivo de ejemplo.

# Supabase - CUENTA DEL CLIENTE (Integra Legal)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=
CRON_SECRET=

# eFactura PTY (PAC ideati)
# EFACTURA_I_AMB: 1=produccion, 2=pruebas
EFACTURA_API_BASE_URL=
EFACTURA_I_AMB=
EFACTURA_API_KEY=
