# Supabase - CUENTA DEL CLIENTE (Integra Legal)
# Solicitar estas credenciales al cliente antes de configurar
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL base pública de la app (opcional).
# Cascada en runtime: NEXT_PUBLIC_APP_URL → https://${VERCEL_URL} → fallback prod.
# Si dejas este valor vacío, en preview/prod Vercel inyecta VERCEL_URL
# automáticamente y los emails apuntan al deploy correcto. Solo configurar
# si querés un dominio propio (ej. https://crm.integra-panama.com).
NEXT_PUBLIC_APP_URL=
